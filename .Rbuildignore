# RStudio and Project Locks
^\.Rproj\.user$
^\.Rhistory$
^pgdcm/\.Rhistory$
\.Rproj\.user
^docs$
^_pkgdown\.yml$
^renv$
^renv\.lock$

# Tutorial and Vignette Caches (Prevents Bloat)
^vignettes/Beginner_Tutorial copy\.qmd$
^vignettes/generate_tutorial_data copy\.R$
^vignettes/renv$
^vignettes/.*\.rds$
^vignettes/.*\.csv$
^vignettes/.*\.pdf$
^vignettes/generate_.*\.R$
^vignettes_locked$

# Local Directories
^locallib$

# Hidden Quarto Environment Locks
^vignettes/\.quarto$
^vignettes_locked/\.quarto$
^\.Rproj\.user$
^\.Rhistory$
^DCM_.*\.pdf$
^\.pkgdownignore$
^\.github$
^\.rcache$
# Local Caches and Test Artifacts
^\.cache$
^\.deno$
^.*\.Rcheck$
^test_.*\.csv$
^Rplots\.pdf$
^DCM_.*\.csv$

# NCME Presentation Folder
^NCME26$
